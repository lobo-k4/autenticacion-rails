<div class="min-h-screen bg-gradient-to-br from-indigo-50 to-blue-50">
  <!-- Navigation Bar -->
  <nav class="bg-white shadow">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold bg-gradient-to-r from-indigo-600 to-blue-600 bg-clip-text text-transparent">
        Auth App
      </h1>
      <div class="flex gap-4">
        <%= link_to "Mi Perfil", edit_registration_path, class: "text-indigo-600 font-semibold hover:text-indigo-700 transition" if Current.user %>
        <%= link_to "Cerrar Sesión", session_path, method: :delete, class: "bg-gradient-to-r from-indigo-600 to-blue-600 text-white px-6 py-2 rounded-lg hover:from-indigo-700 hover:to-blue-700 transition" %>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="max-w-6xl mx-auto px-6 py-12">
    <!-- Welcome Section -->
    <div class="mb-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">
        ¡Bienvenido, <span class="bg-gradient-to-r from-indigo-600 to-blue-600 bg-clip-text text-transparent"><%= Current.user.email_address %></span>!
      </h2>
      <p class="text-xl text-gray-600">
        Tu sesión está activa y segura. Explora todas las características disponibles.
      </p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <!-- Security Status -->
      <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-green-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-semibold mb-1">Estado de Seguridad</p>
            <p class="text-2xl font-bold text-green-600">Seguro</p>
          </div>
          <svg class="h-12 w-12 text-green-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </div>
      </div>

      <!-- Account Type -->
      <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-indigo-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-semibold mb-1">Tipo de Cuenta</p>
            <p class="text-2xl font-bold text-indigo-600">Premium</p>
          </div>
          <svg class="h-12 w-12 text-indigo-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13 7H7v6h6V7z"></path>
            <path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1h-2v1a1 1 0 11-2 0v-1H7a2 2 0 01-2-2v-2H4a1 1 0 110-2h1V9H4a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM9 5a1 1 0 11-2 0 1 1 0 012 0z" clip-rule="evenodd"></path>
          </svg>
        </div>
      </div>

      <!-- Last Activity -->
      <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-blue-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-gray-600 text-sm font-semibold mb-1">Última Actividad</p>
            <p class="text-2xl font-bold text-blue-600">Ahora</p>
          </div>
          <svg class="h-12 w-12 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.586L7.707 9.293a1 1 0 00-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 10.586V7z" clip-rule="evenodd"></path>
          </svg>
        </div>
      </div>
    </div>

    <!-- Features Section -->
    <div class="bg-white rounded-xl shadow-lg p-8 mb-12">
      <h3 class="text-2xl font-bold text-gray-900 mb-6">Características Disponibles</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="p-4 border border-gray-200 rounded-lg hover:shadow-lg transition">
          <svg class="h-8 w-8 text-indigo-600 mb-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5.951-1.429 5.951 1.429a1 1 0 001.169-1.409l-7-14z"></path>
          </svg>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">Autenticación Segura</h4>
          <p class="text-gray-600 text-sm">Acceso protegido con contraseña encriptada</p>
        </div>

        <!-- Feature 2 -->
        <div class="p-4 border border-gray-200 rounded-lg hover:shadow-lg transition">
          <svg class="h-8 w-8 text-indigo-600 mb-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
          </svg>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">Gestión de Contraseña</h4>
          <p class="text-gray-600 text-sm">Cambia tu contraseña en cualquier momento</p>
        </div>

        <!-- Feature 3 -->
        <div class="p-4 border border-gray-200 rounded-lg hover:shadow-lg transition">
          <svg class="h-8 w-8 text-indigo-600 mb-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
          </svg>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">Recuperación de Cuenta</h4>
          <p class="text-gray-600 text-sm">Recupera acceso si olvidas tu contraseña</p>
        </div>

        <!-- Feature 4 -->
        <div class="p-4 border border-gray-200 rounded-lg hover:shadow-lg transition">
          <svg class="h-8 w-8 text-indigo-600 mb-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M13 7H7v6h6V7z"></path>
            <path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1h-2v1a1 1 0 11-2 0v-1H7a2 2 0 01-2-2v-2H4a1 1 0 110-2h1V9H4a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM9 5a1 1 0 11-2 0 1 1 0 012 0z" clip-rule="evenodd"></path>
          </svg>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">Sesión Activa</h4>
          <p class="text-gray-600 text-sm">Monitorea tu actividad en línea</p>
        </div>

        <!-- Feature 5 -->
        <div class="p-4 border border-gray-200 rounded-lg hover:shadow-lg transition">
          <svg class="h-8 w-8 text-indigo-600 mb-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.586L7.707 9.293a1 1 0 00-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 10.586V7z" clip-rule="evenodd"></path>
          </svg>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">Soporte 24/7</h4>
          <p class="text-gray-600 text-sm">Ayuda disponible en cualquier momento</p>
        </div>

        <!-- Feature 6 -->
        <div class="p-4 border border-gray-200 rounded-lg hover:shadow-lg transition">
          <svg class="h-8 w-8 text-indigo-600 mb-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">Privacidad Garantizada</h4>
          <p class="text-gray-600 text-sm">Tus datos están completamente protegidos</p>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <!-- Update Profile -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Actualizar Perfil</h3>
        <p class="text-gray-600 mb-6">Mantén tu información de perfil actualizada y segura.</p>
        <%= link_to "Editar Perfil", edit_registration_path, class: "inline-block bg-gradient-to-r from-indigo-600 to-blue-600 text-white px-6 py-3 rounded-lg hover:from-indigo-700 hover:to-blue-700 transition transform hover:scale-105" %>
      </div>

      <!-- Change Password -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Cambiar Contraseña</h3>
        <p class="text-gray-600 mb-6">Actualiza tu contraseña para mayor seguridad.</p>
        <%= link_to "Cambiar Contraseña", new_password_path, class: "inline-block bg-gradient-to-r from-indigo-600 to-blue-600 text-white px-6 py-3 rounded-lg hover:from-indigo-700 hover:to-blue-700 transition transform hover:scale-105" %>
      </div>
    </div>
  </div>
</div>
