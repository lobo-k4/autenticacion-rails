<div class="min-h-screen bg-gradient-to-br from-indigo-50 to-blue-50 py-12 px-4">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <%= link_to "← Volver", root_path, class: "text-indigo-600 font-semibold hover:text-indigo-700 transition mb-4 inline-block" %>
      <h1 class="text-4xl font-bold text-gray-900">Editar Perfil</h1>
      <p class="text-gray-600 mt-2">Actualiza tu información personal</p>
    </div>

    <!-- Card Container -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <!-- Form Content -->
      <div class="p-8">
        <% if @user.errors.any? %>
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
            <h3 class="text-red-800 font-semibold mb-2">Errores al guardar:</h3>
            <ul class="text-red-600 text-sm space-y-1 list-disc list-inside">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @user, url: registration_path, method: :patch, local: true do |f| %>
          <!-- Email Field -->
          <div class="mb-6">
            <%= f.label :email_address, "Email", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                </svg>
              </div>
              <%= f.email_field :email_address, 
                  required: true,
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
            <p class="text-gray-500 text-sm mt-2">Este es tu email de acceso a la cuenta</p>
          </div>

          <!-- Password Field -->
          <div class="mb-6">
            <%= f.label :password, "Contraseña Actual", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <%= f.password_field :password, 
                  placeholder: "Deja vacío para no cambiar",
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
            <p class="text-gray-500 text-sm mt-2">Requerido para cambios de seguridad</p>
          </div>

          <!-- Password Confirmation Field -->
          <div class="mb-8">
            <%= f.label :password_confirmation, "Confirmar Contraseña", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <%= f.password_field :password_confirmation, 
                  placeholder: "Repite tu contraseña",
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
          </div>

          <!-- Button Group -->
          <div class="flex gap-4 flex-col sm:flex-row">
            <%= f.submit "Guardar Cambios", class: "flex-1 bg-gradient-to-r from-indigo-600 to-blue-600 text-white font-bold py-3 rounded-lg hover:from-indigo-700 hover:to-blue-700 transition duration-200 transform hover:scale-105 shadow-lg" %>
            <%= link_to "Cancelar", root_path, class: "flex-1 bg-gray-200 text-gray-800 font-bold py-3 rounded-lg hover:bg-gray-300 transition duration-200 text-center" %>
          </div>
        <% end %>

        <!-- Divider -->
        <div class="mt-8 relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">Zona de Peligro</span>
          </div>
        </div>

        <!-- Delete Account Section -->
        <div class="mt-8 p-6 bg-red-50 border border-red-200 rounded-lg">
          <h3 class="text-lg font-semibold text-red-800 mb-2">Eliminar Cuenta</h3>
          <p class="text-gray-600 text-sm mb-4">
            Una vez que elimines tu cuenta, no hay forma de recuperarla. Por favor sé seguro.
          </p>
          <%= button_to "Eliminar Mi Cuenta", registration_path, 
              method: :delete, 
              data: { confirm: "¿Estás seguro? Esta acción es irreversible." },
              class: "bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 transition font-semibold" %>
        </div>
      </div>
    </div>

    <!-- Info Box -->
    <div class="mt-8 p-4 bg-white rounded-xl shadow text-center">
      <p class="text-gray-600 text-sm">
        ¿Necesitas más ayuda? <%= link_to "Contacta soporte", "#", class: "text-indigo-600 font-semibold hover:text-indigo-700" %>
      </p>
    </div>
  </div>
</div>
