<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-50 to-blue-50 py-12 px-4">
  <div class="w-full max-w-md">
    <!-- Card Container -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <!-- Header -->
      <div class="bg-gradient-to-r from-indigo-600 to-blue-600 px-8 py-12 text-center">
        <h1 class="text-4xl font-bold text-white mb-2">Crear Cuenta</h1>
        <p class="text-indigo-100">Únete a nuestra comunidad hoy</p>
      </div>

      <!-- Form Content -->
      <div class="px-8 py-8">
        <%= form_with model: @user, url: registration_path, local: true do |f| %>
          <!-- Email Field -->
          <div class="mb-6">
            <%= f.label :email_address, "Email", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                </svg>
              </div>
              <%= f.email_field :email_address, 
                  required: true, 
                  placeholder: "tu@email.com",
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
          </div>

          <!-- Password Field -->
          <div class="mb-6">
            <%= f.label :password, "Contraseña", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <%= f.password_field :password, 
                  required: true, 
                  placeholder: "Mínimo 8 caracteres",
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
          </div>

          <!-- Password Confirmation Field -->
          <div class="mb-8">
            <%= f.label :password_confirmation, "Confirmar Contraseña", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <%= f.password_field :password_confirmation, 
                  required: true, 
                  placeholder: "Repite tu contraseña",
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
          </div>

          <!-- Submit Button -->
          <%= f.submit "Crear Cuenta", class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 text-white font-bold py-3 rounded-lg hover:from-indigo-700 hover:to-blue-700 transition duration-200 transform hover:scale-105 shadow-lg" %>
        <% end %>

        <!-- Divider -->
        <div class="mt-8 relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">¿Ya tienes cuenta?</span>
          </div>
        </div>

        <!-- Login Link -->
        <div class="mt-8 text-center">
          <%= link_to "Inicia sesión aquí", new_session_path, class: "text-indigo-600 font-semibold hover:text-indigo-700 transition duration-200" %>
        </div>
      </div>
    </div>

    <!-- Footer Text -->
    <p class="text-center text-gray-600 text-sm mt-6">
      Estás creando una cuenta segura con encriptación de nivel empresarial
    </p>
  </div>
</div>