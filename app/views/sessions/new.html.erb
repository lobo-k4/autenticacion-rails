<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-50 to-blue-50 py-12 px-4">
  <div class="w-full max-w-md">
    <!-- Card Container -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <!-- Header -->
      <div class="bg-gradient-to-r from-indigo-600 to-blue-600 px-8 py-12 text-center">
        <h1 class="text-4xl font-bold text-white mb-2">Bienvenido</h1>
        <p class="text-indigo-100">Inicia sesión en tu cuenta</p>
      </div>

      <!-- Form Content -->
      <div class="px-8 py-8">
        <!-- Flash Messages -->
        <% if alert = flash[:alert] %>
          <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg flex items-start" id="alert">
            <svg class="h-5 w-5 text-red-500 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
            <span><%= alert %></span>
          </div>
        <% end %>

        <% if notice = flash[:notice] %>
          <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg flex items-start" id="notice">
            <svg class="h-5 w-5 text-green-500 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span><%= notice %></span>
          </div>
        <% end %>

        <%= form_with url: session_url, local: true do |form| %>
          <!-- Email Field -->
          <div class="mb-6">
            <%= form.label :email_address, "Email", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                </svg>
              </div>
              <%= form.email_field :email_address, 
                  required: true, 
                  autofocus: true, 
                  autocomplete: "username", 
                  placeholder: "tu@email.com",
                  value: params[:email_address],
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
          </div>

          <!-- Password Field -->
          <div class="mb-8">
            <%= form.label :password, "Contraseña", class: "block text-sm font-semibold text-gray-700 mb-2" %>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-indigo-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <%= form.password_field :password, 
                  required: true, 
                  autocomplete: "current-password", 
                  maxlength: 72,
                  placeholder: "Tu contraseña",
                  class: "w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition duration-200" %>
            </div>
          </div>

          <!-- Submit Button -->
          <%= form.submit "Iniciar Sesión", class: "w-full bg-gradient-to-r from-indigo-600 to-blue-600 text-white font-bold py-3 rounded-lg hover:from-indigo-700 hover:to-blue-700 transition duration-200 transform hover:scale-105 shadow-lg" %>
        <% end %>

        <!-- Divider -->
        <div class="mt-8 relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">Opciones adicionales</span>
          </div>
        </div>

        <!-- Help Links -->
        <div class="mt-8 space-y-3">
          <div class="text-center">
            <%= link_to "¿Olvidaste tu contraseña?", new_password_path, class: "text-indigo-600 font-semibold hover:text-indigo-700 transition duration-200 block" %>
          </div>
          <div class="text-center">
            <%= link_to "Crear nueva cuenta", new_registration_path, class: "text-indigo-600 font-semibold hover:text-indigo-700 transition duration-200 block" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Text -->
    <p class="text-center text-gray-600 text-sm mt-6">
      Tu privacidad y seguridad son nuestras prioridades
    </p>
  </div>
</div>
